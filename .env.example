# Gmail Customer Query Agent — environment variables
#
# Copy this file to `.env` and fill in real values. Never commit `.env`
# (it is gitignored). In production these are set as GitHub Actions repository
# secrets, not via a file. See docs/auth-setup.md.

# --- Google OAuth (from scripts/setup_oauth.py) ---
# OAuth 2.0 Desktop-app client credentials.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Long-lived refresh token obtained from the one-time consent flow.
GOOGLE_REFRESH_TOKEN=your-refresh-token

# --- Google Drive ---
# ID of the Drive folder holding the approved knowledge documents
# (the part of the folder URL after /folders/).
DRIVE_FOLDER_ID=your-drive-folder-id

# --- Groq ---
# API key for the triage and drafting LLM passes.
GROQ_API_KEY=your-groq-api-key

# --- Optional: model overrides (defaults shown) ---
TRIAGE_MODEL=llama-3.1-8b-instant
DRAFTING_MODEL=llama-3.3-70b-versatile

# --- Optional: run configuration ---
# Max threads processed per steady-state run. 0 or unset = unlimited.
MAX_EMAILS_PER_RUN=0
# First-run backfill: on the very first run (before the Agent-Processed label
# exists), look back this many hours instead of the usual 90 minutes.
# 0 or unset = disabled (use the normal window even on the first run).
FIRST_RUN_HOURS=0
# Cap on threads handled during that first backfill run. 0 or unset = unlimited.
FIRST_RUN_MAX_EMAILS=0
